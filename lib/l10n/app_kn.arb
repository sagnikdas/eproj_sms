  "onboardingWelcomeBody1": "ಎಲ್ಡರ್ ಶೀಲ್ಡ್ ನಿಮ್ಮ ಸಂದೇಶಗಳು ಮತ್ತು ಕರೆಗಳನ್ನು ಗಮನಿಸಿ, ಮೋಸವಿರಬಹುದು ಎಂದು ಕಂಡುಬಂದರೆ ಮುಂಚಿತವಾಗಿ ಎಚ್ಚರಿಸುತ್ತದೆ.",
  "onboardingWelcomeBody2": "ನೀವು ಅನುಮಾನದಲ್ಲಿ ಇದ್ದರೆ, ಒಂದೇ ಟ್ಯಾಪ್‌ನಿಂದ ನಂಬಿಕೆಯ ವ್ಯಕ್ತಿಗೆ ಕರೆ ಮಾಡಬಹುದು.",
  "onboardingGetStarted": "ಪ್ರಾರಂಭಿಸೋಣ",

  "onboardingPermissionsTitle": "ಈ ಅನುಮತಿಗಳು ಏಕೆ ಬೇಕು",
  "onboardingPermissionsBulletMessages": "ಮೆಸೇಜುಗಳು: ನಿಮ್ಮ ಎಸ್‌ಎಂಎಸ್ ಓದಿ, ಅವುಗಳಲ್ಲಿ ಮೋಸದ ಲಕ್ಷಣಗಳಿದ್ದರೆ ಎಚ್ಚರಿಸಲು.",
  "onboardingPermissionsBulletPhone": "ಫೋನ್: ನೀವು ಯಾವಾಗ ಕರೆಗಳಲ್ಲಿ ಇದ್ದೀರಿ ಎಂದು ತಿಳಿದುಕೊಳ್ಳಲು. ಮೋಸಗಾರರು ಹಲವಾರು ಬಾರಿ ಫೋನ್‌ನಲ್ಲಿ ಮಾತನಾಡಿಸುತ್ತಾ ಒಟಿಪಿ ಕೇಳುತ್ತಾರೆ.",
  "onboardingPermissionsBody1": "ಕೆಳಗಿನ \"ಅನುಮತಿಗಳನ್ನು ನೀಡಿ\" ಮೇಲೆ ಟ್ಯಾಪ್ ಮಾಡಿದಾಗ, ನಿಮ್ಮ ಸಾಧನವು ಮೆಸೇಜುಗಳು, ಫೋನ್ ಮತ್ತು ನೋಟಿಫಿಕೇಶನ್‌ಗಳ ಅನುಮತಿಯನ್ನು ಕೇಳುತ್ತದೆ (ಮೋಸದ ಶಂಕೆಯಿದ್ದರೆ ಆ್ಯಪ್ ಮುಚ್ಚಿದ್ದರೂ ನಾವು ಎಚ್ಚರಿಸಲು).",
  "onboardingPermissionsBody2": "ಮೋಸ ಪರಿಶೀಲನೆಗೆ ಹೊರತು ಬೇರೆ ಯಾವ ಕಾರಣಕ್ಕೂ ನಾವು ನಿಮ್ಮ ಸಂದೇಶಗಳನ್ನು ಓದುತ್ತಿಲ್ಲ.",
  "onboardingPermissionsRetryWarning": "ಕೆಲವು ಅನುಮತಿಗಳನ್ನು ನಿರಾಕರಿಸಲಾಗಿದೆ. ನೀವು ಅವನ್ನು ನೀಡುವವರೆಗೂ ರಕ್ಷಣೆ ಸೀಮಿತವಾಗಿರುತ್ತದೆ.",
  "onboardingPermissionsPrimaryAllow": "ಅನುಮತಿಗಳನ್ನು ನೀಡಿ",
  "onboardingPermissionsPrimaryRetry": "ಮತ್ತೊಮ್ಮೆ ಪ್ರಯತ್ನಿಸಿ",
  "onboardingSkipForNow": "ಈಗ ಇರಲಿ",

  "onboardingTrustedTitle": "ನಂಬಿಕೆಯ ಸಂಪರ್ಕವನ್ನು ಸೇರಿಸಿ",
  "onboardingTrustedBody1": "ಯಾವುದಾದರೂ ಆತಂಕಕಾರಿ ಸಂದೇಶ ಬಂದರೆ ನೀವು ಕರೆ ಮಾಡಲು ಇಚ್ಛಿಸುವ — ಕುಟುಂಬದ ಸದಸ್ಯ ಅಥವಾ ಆಪ್ತ ಸ್ನೇಹಿತನಂತೆ — ಒಬ್ಬರನ್ನು ಆಯ್ಕೆಮಾಡಿ.",
  "onboardingTrustedBody2": "ಇವರನ್ನು ಸೇರಿಸಿದ ನಂತರ, ಹೋಮ್ ಪರದೆ ಅಥವಾ ನಾವು ಮೋಸ ಎಚ್ಚರಿಕೆ ತೋರಿಸಿದಾಗ ಒಂದೇ ಟ್ಯಾಪ್‌ನಿಂದ ಈ ವ್ಯಕ್ತಿಗೆ ಕರೆ ಮಾಡಬಹುದು.",
